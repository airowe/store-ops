# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/

# Secrets / local env (never commit)
.env
.env.local
*.local

# Node / Cloudflare (cloud/ also has its own .gitignore)
node_modules/
.wrangler/
dist/
*.sqlite
*.sqlite-shm
*.sqlite-wal

# OS / editor
.DS_Store
.vscode/
.idea/

# asc CLI run artifacts — machine-generated upload/failure reports (timestamped,
# absolute local paths). Regenerated per run; never committed. Tracked .asc/
# config (e.g. workflow.json) is NOT under reports/, so it stays committable.
.asc/reports/

# Competitive analysis + parity PRDs — kept LOCAL only, never committed.
# (Competitor intel doesn't belong in the product repo; feature work is
# tracked via GitHub issues instead.)
docs/competitive/
cloud/docs/prd/
.superpowers/
