{
  "name": "store-ops-cloud",
  "version": "0.1.0",
  "private": true,
  "description": "Cloudflare-native autonomous ASO agent (store-ops). Workers + D1 + Cron + Pages.",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "db:migrate": "wrangler d1 execute store_ops --file=./schema.sql",
    "db:migrate:local": "wrangler d1 execute store_ops --local --file=./schema.sql"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.8.0",
    "@cloudflare/workers-types": "^4.20250101.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "wrangler": "^3.99.0"
  }
}
