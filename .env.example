# store-ops — optional credentials. Copy to .env and fill in only what you need.
# EVERYTHING works without these (the engine grounds on free iTunes APIs). These
# are optional accelerators that ground keyword VOLUME on real search data, and
# they are always YOUR OWN keys — store-ops never resells data through a shared
# account. .env is gitignored; never commit real values.

# ── Apple Search Ads — real Search Popularity (5–100). Optional. ─────────────
# Org id for this account, plus EITHER a static access token OR client creds.
ASA_ORG_ID=
ASA_ACCESS_TOKEN=
ASA_CLIENT_ID=
ASA_CLIENT_SECRET=

# ── Google Ads Keyword Planner — real avg monthly searches. Optional. ────────
# Needs a Google Ads account + an approved developer token. Customer id digits
# only. EITHER a static access token OR the refresh triple. See GOOGLE_ADS docs.
GADS_DEVELOPER_TOKEN=
GADS_CUSTOMER_ID=
GADS_LOGIN_CUSTOMER_ID=
GADS_ACCESS_TOKEN=
GADS_REFRESH_TOKEN=
GADS_CLIENT_ID=
GADS_CLIENT_SECRET=

# ── context.dev — cleaner competitor-listing + brand-data scraping. Optional. ─
# No key → the skill falls back to WebFetch/Crawl4AI. Never required.
CONTEXT_DEV_API_KEY=
# CONTEXT_DEV_API_BASE=https://api.context.dev/v1
# CONTEXT_DEV_AUTH_HEADER=Authorization
